{
  "info": {
    "name": "Dating Site API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Все маршруты Dating Site — Auth API (8000) + ML API (8001)"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:8000" },
    { "key": "ml_url",   "value": "http://localhost:8001" }
  ],
  "item": [
    {
      "name": "🔐 Auth",
      "item": [
        {
          "name": "Register — GET form",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/register",
            "description": "Страница регистрации"
          }
        },
        {
          "name": "Register — POST",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/register",
            "description": "Создать нового пользователя",
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                { "key": "username",         "value": "testuser",          "type": "text" },
                { "key": "email",            "value": "test@example.com",  "type": "text" },
                { "key": "password",         "value": "password123",       "type": "text" },
                { "key": "confirm_password", "value": "password123",       "type": "text" },
                { "key": "input_key",        "value": "123456",            "type": "text" }
              ]
            }
          }
        },
        {
          "name": "Register — Send Email (verification code)",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/register/send_email",
            "description": "Отправить код верификации на email",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"test@example.com\"\n}"
            }
          }
        },
        {
          "name": "Register — Dop Info GET",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/register/dop-info",
            "description": "Страница доп. информации профиля"
          }
        },
        {
          "name": "Register — Dop Info POST",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/register/dop-info",
            "description": "Сохранить доп. информацию (возраст, пол, аватар и т.д.)",
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "age",      "value": "25",        "type": "text" },
                { "key": "gender",   "value": "male",      "type": "text" },
                { "key": "name",     "value": "Test User", "type": "text" },
                { "key": "location", "value": "Moscow",    "type": "text" },
                { "key": "bio",      "value": "Hi there",  "type": "text" },
                { "key": "file",     "src": [],            "type": "file", "description": "Аватар (jpg/png)" }
              ]
            }
          }
        },
        {
          "name": "Login — GET form",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/login",
            "description": "Страница входа"
          }
        },
        {
          "name": "Login — POST",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/login",
            "description": "Войти в аккаунт",
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                { "key": "username", "value": "kirill_000",   "type": "text" },
                { "key": "password", "value": "password123",  "type": "text" }
              ]
            }
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/logout",
            "description": "Выйти из аккаунта (очищает сессию)"
          }
        }
      ]
    },
    {
      "name": "🔑 Forgot",
      "item": [
        {
          "name": "Forgot Password — GET form",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/forgot/forgot_password",
            "description": "Страница восстановления пароля"
          }
        },
        {
          "name": "Forgot Password — POST",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/forgot/password",
            "description": "Сменить пароль по username",
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                { "key": "username",     "value": "kirill_000", "type": "text" },
                { "key": "new_password", "value": "newpass456", "type": "text" }
              ]
            }
          }
        },
        {
          "name": "Forgot Username — GET form",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/forgot/username",
            "description": "Страница восстановления по email"
          }
        },
        {
          "name": "Forgot Username — POST",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/forgot/username",
            "description": "Сменить пароль по email",
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                { "key": "email",        "value": "test@example.com", "type": "text" },
                { "key": "new_password", "value": "newpass456",       "type": "text" }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "🤖 ML Service",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "url": "{{ml_url}}/health",
            "description": "Статус ML сервиса и загружена ли модель"
          }
        },
        {
          "name": "Train Model",
          "request": {
            "method": "POST",
            "url": "{{ml_url}}/train",
            "description": "Обучить модель на данных из БД"
          }
        },
        {
          "name": "Rank Candidates",
          "request": {
            "method": "POST",
            "url": "{{ml_url}}/rank",
            "description": "Ранжировать кандидатов для пользователя",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"current_user\": \"kirill_000\",\n  \"candidates\": [\"ksenia_002\", \"maria_004\", \"anna_007\"]\n}"
            }
          }
        }
      ]
    },
    {
      "name": "📄 Docs",
      "item": [
        {
          "name": "API Swagger UI",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/docs",
            "description": "Интерактивная документация FastAPI"
          }
        },
        {
          "name": "ML Swagger UI",
          "request": {
            "method": "GET",
            "url": "{{ml_url}}/docs",
            "description": "Интерактивная документация ML сервиса"
          }
        },
        {
          "name": "API OpenAPI JSON",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/openapi.json"
          }
        }
      ]
    }
  ]
}
