            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@example.com\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/register/send_email",
              "host": ["{{base_url}}"],
              "path": ["register", "send_email"]
            },
            "description": "Отправить письмо с подтверждением email"
          }
        }
