                { "key": "location", "value": "Moscow", "type": "text" },
                { "key": "bio", "value": "Люблю путешествовать и читать книги", "type": "text" },
                { "key": "file", "type": "file", "src": "" }
              ]
            },
            "url": {
              "raw": "{{base_url}}/register/dop-info",
