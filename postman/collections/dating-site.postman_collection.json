                { "key": "email", "value": "user@example.com", "type": "text" },
                { "key": "password", "value": "securepassword123", "type": "text" },
                { "key": "confirm_password", "value": "securepassword123", "type": "text" },
                { "key": "input_key", "value": "1234", "type": "text" },
                { "key": "age", "value": "25", "type": "text" },
                { "key": "gender", "value": "male", "type": "text" },
                { "key": "location", "value": "Moscow", "type": "text" }
